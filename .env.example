SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Database (MySQL untuk development / production)
DB_ENGINE=django.db.backends.mysql
DB_NAME=sistem_pakar_sapi
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306

# Untuk SQLite (development ringan), uncomment dan comment MySQL di atas:
# DB_ENGINE=django.db.backends.sqlite3
# DB_NAME=db.sqlite3

# Untuk PostgreSQL (production), uncomment dan isi:
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=sistem_pakar_sapi
# DB_USER=postgres
# DB_PASSWORD=password
# DB_HOST=localhost
# DB_PORT=5432
